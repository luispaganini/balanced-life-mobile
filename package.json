{
  "name": "veben",
  "main": "expo-router/entry",
  "version": "1.0.11",
  "scripts": {
    "start": "expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest --watchAll",
    "lint": "expo lint",
    "detox:build": "detox build --configuration android.emu.release",
    "detox:test": "detox test --configuration android.emu.release"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/__mocks__/jest.setup.ts"
    ],
    "moduleNameMapper": {
      "^react-i18next$": "<rootDir>/__mocks__/react-i18next.ts"
    },
    "testPathIgnorePatterns": [
      "<rootDir>/e2e/"
    ]
  },
  "dependencies": {
    "@expo/config-plugins": "^56.0.8",
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "9.1.0",
    "@react-native-google-signin/google-signin": "^16.1.2",
    "@react-navigation/native": "^6.0.2",
    "axios": "^1.7.2",
    "expo": "^56.0.8",
    "expo-constants": "~56.0.16",
    "expo-dev-client": "~56.0.18",
    "expo-font": "~56.0.5",
    "expo-image-picker": "~56.0.15",
    "expo-linear-gradient": "~56.0.4",
    "expo-linking": "~56.0.13",
    "expo-network": "~56.0.4",
    "expo-notifications": "~56.0.15",
    "expo-router": "~56.2.8",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "expo-system-ui": "~56.0.5",
    "expo-web-browser": "~56.0.5",
    "i18next": "^23.11.5",
    "intl-pluralrules": "^2.0.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-hook-form": "^7.51.5",
    "react-i18next": "^14.1.2",
    "react-native": "0.85.3",
    "react-native-chart-kit": "^6.12.0",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-gifted-charts": "^1.4.14",
    "react-native-masked-text": "^1.13.0",
    "react-native-otp-entry": "^1.7.0",
    "react-native-paper": "^5.12.3",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-vector-icons": "^10.1.0",
    "react-native-web": "^0.21.2",
    "react-native-worklets": "0.8.3",
    "styled-components": "^6.4.2",
    "zustand": "^4.5.2"
  },
  "devDependencies": {
    "@babel/core": "^7.20.0",
    "@config-plugins/detox": "^11.0.0",
    "@jest/globals": "^30.4.1",
    "@react-native/jest-preset": "^0.85.3",
    "@testing-library/jest-native": "^5.4.3",
    "@testing-library/react-native": "^12.8.1",
    "@types/jest": "29.5.14",
    "@types/react": "~19.2.14",
    "@types/react-test-renderer": "^18.0.7",
    "detox": "^20.51.3",
    "jest": "^29.2.1",
    "jest-expo": "~56.0.4",
